# AIOS Environment Variables — Example
# Copy this to .env and fill in your actual keys
# Never commit .env to git

# Google Calendar API
# GOOGLE_CALENDAR_API_KEY=

# Gmail API (read-only)
# GMAIL_API_KEY=

# Google OAuth Credentials (Gmail + Calendar MCPs)
# Path to downloaded credentials.json from Google Cloud Console
# GMAIL_CREDENTIALS_PATH=/path/to/credentials.json
# GOOGLE_CALENDAR_CREDENTIALS_PATH=/path/to/credentials.json
# (These can point to the same file if using one OAuth client for both)

# Google OAuth Client (if passing credentials directly)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Add new connections here as they're wired
